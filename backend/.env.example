# 所有設定支援三種環境變數名稱（優先序）：STAFFDECK_<名稱> > ULTRARAG_<名稱> > <名稱>。
# 下方使用不帶前綴的名稱；若與其他系統衝突可改用 STAFFDECK_ 前綴（例：STAFFDECK_DATABASE_URL）。
# 啟動載入設定用的 dotenv 路徑與資料目錄：STAFFDECK_DOTENV / STAFFDECK_DATA_DIR（相容 ULTRARAG_DOTENV / ULTRARAG_DATA_DIR）。
APP_NAME="Skill Agent Loop Service"
DATABASE_URL="sqlite:///./skill_agent_loop.db"
APP_SECRET="change-me-in-development"
# provider: openai_compatible（預設）或 gemini
DEMO_MODEL_PROVIDER="openai_compatible"
DEMO_MODEL_BASE_URL="http://58.57.119.12:52010/v1"
DEMO_MODEL_NAME="qwen3.6-27b"
DEMO_MODEL_API_KEY=""
# 使用 Google Gemini 時，改成以下設定（base_url 留空會自動用 Google OpenAI 相容端點）：
#   DEMO_MODEL_PROVIDER="gemini"
#   DEMO_MODEL_BASE_URL=""
#   DEMO_MODEL_NAME="gemini-2.5-flash"
#   DEMO_MODEL_API_KEY="<你的 Google AI Studio API key>"
MODEL_THINKING_MODE=""
MODEL_THINKING_MODELS=""
TOOL_TIMEOUT_SECONDS="8"
TOOL_BASE_URL="http://localhost:5173"
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
GENERAL_SKILL_RUNTIME_PYTHON=""
GENERAL_SKILL_RUNTIME_VENV=""
GENERAL_SKILL_RUNTIME_PACKAGES="requests,httpx"
GENERAL_SKILL_RUNTIME_AUTO_INSTALL="true"
